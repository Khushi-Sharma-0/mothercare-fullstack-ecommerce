# Copy this file to .env and fill in your own values.

# Port the backend API server runs on
PORT=4000

# Secret used to sign login sessions (JWTs). Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-string

# Optional: your frontend's URL, used for Stripe redirect links
CLIENT_URL=http://localhost:5500

# Optional: Stripe secret key (starts with sk_test_ or sk_live_).
# If left blank, checkout still works using a simulated payment so you can
# test the full flow without a Stripe account.
STRIPE_SECRET_KEY=
